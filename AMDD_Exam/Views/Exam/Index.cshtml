@model AMDD_Exam.Models.ExamStartViewModel
@{ ViewData["Title"] = "Skills Assessment"; }

<div class="d-flex justify-content-center align-items-center" style="min-height:70vh;">
    <div style="width:100%;max-width:460px;">
        <div class="card shadow border-0">

            <div class="text-center py-5 px-4"
                 style="background:linear-gradient(160deg,var(--amdd-900) 0%,var(--amdd-700) 100%);">
                <img src="~/favicon.png" alt="AMDD"
                     style="width:76px;height:76px;filter:brightness(0) invert(1);
                            display:block;margin:0 auto 1rem;" />
                <h2 class="text-white fw-bold mb-1">AMDD Skills Assessment</h2>
                <p class="mb-0" style="color:#d9b8ff;font-size:0.9rem;">
                    Branch Banking Application Development Unit
                </p>
            </div>

            <div class="px-4 py-4">
                <p class="text-center mb-4" style="color:#4a3060;">
                    Answer all questions honestly and to the best of your ability.
                </p>
                <div class="alert mb-4 text-center fw-semibold"
                     style="background:var(--amdd-100);border:2px solid var(--amdd-500);
                            color:var(--amdd-900);border-radius:8px;font-size:0.95rem;">
                    ⏱ You have <strong>30 minutes</strong> to complete this exam.<br />
                    <small class="fw-normal" style="color:var(--amdd-700);">
                        The exam will auto-submit when time runs out.
                    </small>
                </div>
                <form asp-action="Start" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-4">
                        <label class="fw-semibold d-block mb-1" style="color:#2d0a4e;">Full Name</label>
                        <input asp-for="ApplicantName"
                               class="form-control form-control-lg"
                               placeholder="e.g. Chelsie F. Esquero"
                               autocomplete="off"
                               style="border:2px solid var(--amdd-400);border-radius:8px;" />
                        <span asp-validation-for="ApplicantName" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-lg fw-bold w-100"
                            style="background:var(--amdd-700);color:#fff;border:none;
                                   padding:14px;font-size:1.05rem;border-radius:8px;">
                        Start Exam →
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
