@model AMDD_Exam.Models.ExamStartViewModel
@{
    ViewData["Title"] = "Skills Assessment";
}

<div class="row justify-content-center" style="min-height:80vh;align-items:center;margin:0;">
    <div class="col-12 col-sm-10 col-md-7 col-lg-5 py-4">
        <div class="card shadow border-0" style="border-radius:16px;overflow:hidden;">

            <!-- Hero header -->
            <div class="text-center py-5 px-4"
                 style="background:linear-gradient(160deg,var(--amdd-900) 0%,var(--amdd-700) 100%);">
                <img src="~/favicon.png" alt="AMDD Trophy"
                     style="width:80px;height:80px;filter:brightness(0) invert(1);
                            display:block;margin:0 auto 1.25rem;" />
                <h2 class="text-white fw-bold mb-1" style="font-size:1.75rem;">
                    AMDD Skills Assessment
                </h2>
                <p class="mb-0" style="color:#d9b8ff;font-size:0.9rem;">
                    Branch Banking Application Development Unit
                </p>
            </div>

            <!-- Form body -->
            <div class="card-body px-4 py-4">
                <p class="text-center mb-4" style="color:#4a3060;font-size:0.95rem;">
                    Answer all questions honestly and to the best of your ability.
                </p>

                <form asp-action="Start" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-4">
                        <label asp-for="ApplicantName"
                               class="form-label fw-semibold mb-2"
                               style="color:#2d0a4e;">Full Name</label>
                        <input asp-for="ApplicantName"
                               class="form-control form-control-lg"
                               placeholder="e.g. Juan dela Cruz"
                               autocomplete="off"
                               style="border:2px solid var(--amdd-400);
                                      border-radius:8px;font-size:1rem;" />
                        <span asp-validation-for="ApplicantName"
                              class="text-danger small"></span>
                    </div>
                    <div class="d-grid mb-2">
                        <button type="submit"
                                class="btn btn-lg fw-bold"
                                style="background:var(--amdd-700);color:#fff;
                                       border:none;padding:15px;
                                       font-size:1.1rem;border-radius:8px;
                                       letter-spacing:0.02em;">
                            Start Exam →
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
